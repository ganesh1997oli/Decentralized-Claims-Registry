# Copy to .env.local, fill in the values, then load it with:
# set -a; source backend/.env.local; set +a

SEPOLIA_RPC_URL=""

# Fresh, Sepolia-only demonstration wallet. Never use a wallet holding real assets.
SEPOLIA_PRIVATE_KEY=""

# Pinata JWT with public Files write access. Synthetic data only.
PINATA_JWT=""
IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"

MODULE_ID="ClaimsRegistryModule#ClaimsRegistry"
RECEIPT_TIMEOUT="180"
