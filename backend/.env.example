# Copy to .env.local and load it together with integrations/ipfs/.env.local.

SEPOLIA_RPC_URL=""

# Fresh, Sepolia-only demonstration wallet. Never use a wallet holding real assets.
SEPOLIA_PRIVATE_KEY=""

MODULE_ID="ClaimsRegistryModule#ClaimsRegistry"
RECEIPT_TIMEOUT="180"

# Versioned JSON artifact used for transparent Week 5 inference.
FRAUD_MODEL_PATH="model/artifacts/synthetic-logistic-v1.json"

# Comma-separated browser origins allowed to call FastAPI.
FRONTEND_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
