# Copy this file to .env.local (ignored by git), fill it in, then load it:
# set -a; source .env.local; set +a

SEPOLIA_RPC_URL=""

# Use a fresh Sepolia-only key. Never use a wallet that holds real assets.
SEPOLIA_PRIVATE_KEY=""

# Pinata JWT with public Files write access. Keep it server-side and out of git.
PINATA_JWT=""

# Public gateway used by both the uploader's round-trip check and the listener.
IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"
