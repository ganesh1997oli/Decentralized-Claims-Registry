# Copy this file to .env.local (ignored by git), fill it in, then load it:
# set -a; source .env.local; set +a

SEPOLIA_RPC_URL=""

# Use a fresh Sepolia-only key. Never use a wallet that holds real assets.
SEPOLIA_PRIVATE_KEY=""

# Pinata JWT with public Files write access. Keep it server-side and out of git.
PINATA_JWT=""

# Public gateway used by both the uploader's round-trip check and the listener.
IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"

# Kafka is optional so the old listener still works. Turn it on after starting
# the local broker from listener/kafka/compose.yml.
KAFKA_ENABLED="false"
KAFKA_BOOTSTRAP_SERVERS="127.0.0.1:9092"
KAFKA_CLAIM_SUBMITTED_TOPIC="claims.submitted.v1"
KAFKA_CLIENT_ID="claims-registry-listener"
KAFKA_CONSUMER_GROUP_ID="claims-registry-verifier-v1"
KAFKA_DELIVERY_TIMEOUT_MS="30000"
KAFKA_CONSUMER_POLL_SECONDS="1"

# Local Docker uses PLAINTEXT. A hosted production cluster should use SASL_SSL
# or SSL and load its credentials from a secret manager.
KAFKA_SECURITY_PROTOCOL="PLAINTEXT"
KAFKA_SASL_MECHANISM=""
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""

# The listener saves its last fully published block under listener/.state/.
# Set this only when you intentionally want a first-run historical backfill.
LISTENER_START_BLOCK=""
