# Rename this file to .env (contract/.env is gitignored)
# Hardhat does NOT auto-load .env; export into your shell before deploying:
# set -a; source .env; set +a
# Or export them manually. They are only needed for --network sepolia.

SEPOLIA_RPC_URL=""

# Use a FRESH key. The old one committed to git history is compromised forever.
SEPOLIA_PRIVATE_KEY=""