# Copy this file to .env.local. Load it with the IPFS environment and, when
# enabled, the Kafka environment described in listener/README.md.

SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Needed only by submit_and_assess_demo.py. The read-only listener does not sign.
SEPOLIA_PRIVATE_KEY="0x302958f35b98d20470f7da846f2fc2b22c3493d9f5420bc0d309494c8ba6fa36"

MODULE_ID="ClaimsRegistryModule#ClaimsRegistry"
POLL_INTERVAL="5"
CONFIRMATION_BLOCKS="2"

# The listener saves its last fully published block under listener/.state/.
# Set this only when you intentionally want a first-run historical backfill.
LISTENER_START_BLOCK=""
