# Copy this file to .env.local and keep the local file out of Git.

KAFKA_ENABLED="false"
KAFKA_BOOTSTRAP_SERVERS="127.0.0.1:9092"
KAFKA_CLAIM_SUBMITTED_TOPIC="claims.submitted.v1"
KAFKA_CLIENT_ID="claims-registry-listener"
KAFKA_CONSUMER_GROUP_ID="claims-registry-verifier-v1"
KAFKA_DELIVERY_TIMEOUT_MS="30000"
KAFKA_CONSUMER_POLL_SECONDS="1"

# Local Docker uses PLAINTEXT. A hosted cluster should normally use SASL_SSL or
# SSL and load its credentials from a secret manager.
KAFKA_SECURITY_PROTOCOL="PLAINTEXT"
KAFKA_SASL_MECHANISM=""
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""
